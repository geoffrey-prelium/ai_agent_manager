<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Res Config Settings -->
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.ai_manager.agent</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="90"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="AI Agents" string="AI Agents" name="ai_agent_manager">
                    <block title="API Integration" name="api_integration">
                        <setting id="api_keys" title="OpenAI API Integration" string="OpenAI API Configuration" help="Set your OpenAI API Key for agents to work.">
                            <field name="ai_agent_openai_api_key"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

</odoo>
