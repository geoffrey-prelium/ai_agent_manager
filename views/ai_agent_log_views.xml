<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View -->
    <record id="view_ai_agent_log_form" model="ir.ui.view">
        <field name="name">ai_manager.log.form</field>
        <field name="model">ai_manager.log</field>
        <field name="arch" type="xml">
            <form string="Execution Log" create="0" edit="0">
                <header>
                    <button name="action_convert_to_automation" string="Deploy as Automated Action" type="object" class="btn-success" invisible="state != 'success'" groups="ai_agent_manager.group_ai_manager_agent_manager" confirm="This will transform the generated Python code into a native Odoo Automated Action and pause this AI Agent to save tokens. Proceed?"/>
                    <button name="action_validate" string="Validate &amp; Execute" type="object" class="oe_highlight" invisible="state != 'pending'" groups="ai_agent_manager.group_ai_manager_agent_user"/>
                    <button name="action_reject" string="Reject" type="object" invisible="state != 'pending'" groups="ai_agent_manager.group_ai_manager_agent_user"/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,success,failed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="agent_id"/>
                            <field name="task_id"/>
                            <field name="create_date"/>
                        </group>
                        <group>
                            <field name="cost_tokens"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Input/Context" name="input_data">
                            <field name="input_data" widget="text" readonly="1"/>
                        </page>
                        <page string="Output/Response" name="output_data">
                            <field name="output_data" widget="text" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_ai_agent_log_tree" model="ir.ui.view">
        <field name="name">ai_manager.log.tree</field>
        <field name="model">ai_manager.log</field>
        <field name="arch" type="xml">
            <list string="Execution Logs" create="0" edit="0" decoration-danger="state == 'failed'" decoration-warning="state == 'pending'" decoration-success="state == 'success'">
                <field name="create_date"/>
                <field name="agent_id"/>
                <field name="task_id"/>
                <field name="state" widget="badge" decoration-danger="state == 'failed'" decoration-warning="state == 'pending'" decoration-success="state == 'success'"/>
                <field name="cost_tokens"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_ai_agent_log" model="ir.actions.act_window">
        <field name="name">Execution Logs</field>
        <field name="res_model">ai_manager.log</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="ai_agent_log_menu"
              name="Logs"
              parent="ai_agent_menu_agents"
              action="action_ai_agent_log"
              sequence="20"/>

</odoo>
